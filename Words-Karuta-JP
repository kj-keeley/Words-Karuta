/* ===== HUD / FILL ===== */
function updateHUD(animateCombo){
  $("time").textContent = (state.elapsed/1000).toFixed(1);
  const cb=$("combo-banner");
  if(state.combo>=2){
    const mult=Math.min(4,1+Math.floor(state.combo/5)*0.5);
    cb.textContent = (state.combo>=5?"🔥 ":"")+state.combo+" COMBO"+(mult>1?"  ×"+mult.toFixed(mult%1?1:0):"");
    cb.classList.add("show");
    if(animateCombo){ cb.classList.remove("pulse"); void cb.offsetWidth; cb.classList.add("pulse"); }
  } else cb.classList.remove("show");
}
function updateFill(){
  const r = state.capacity ? state.cards.length/state.capacity : 0;
  fillEl.style.width=(Math.min(1,r)*100)+"%";
  fillEl.style.background = r<0.5?"var(--jade)": r<0.75?"var(--gold)":"var(--vermilion)";
  field.classList.toggle("danger", r>=0.75);
  $("fill-txt").textContent = state.cards.length+" / "+state.capacity;
}

/* ===== LOOP ===== */
let lastT=performance.now();
function loop(now){
  const dt=Math.min(0.05,(now-lastT)/1000); lastT=now;
  if(Math.abs(state.score-state.displayScore)>0.5){
    state.displayScore += (state.score-state.displayScore)*0.2;
    $("score").textContent=Math.round(state.displayScore).toLocaleString();
  } else if(Math.round(state.displayScore)!==state.score){
    state.displayScore=state.score; $("score").textContent=state.score.toLocaleString();
  }
  if(state.phase==="playing" && !state.frozen){
    state.elapsed += dt*1000;
    $("time").textContent=(state.elapsed/1000).toFixed(1);
    const inten=intensity();
    const driftNow = cfg().driftBase * (1 + (DRIFT_MAX_MULT-1)*inten);
    const W=state.fieldW, H=state.fieldH, cs=state.cs, maxX=Math.max(0,W-cs), maxY=Math.max(0,H-cs);
    for(const c of state.cards){
      const v = driftNow * c.spd * dt;
      c.x += Math.cos(c.ang)*v; c.y += Math.sin(c.ang)*v;
      if(c.x<0){ c.x=0; c.ang=Math.PI-c.ang+(Math.random()-0.5)*0.4; }
      else if(c.x>maxX){ c.x=maxX; c.ang=Math.PI-c.ang+(Math.random()-0.5)*0.4; }
      if(c.y<0){ c.y=0; c.ang=-c.ang+(Math.random()-0.5)*0.4; }
      else if(c.y>maxY){ c.y=maxY; c.ang=-c.ang+(Math.random()-0.5)*0.4; }
      c.el.style.transform="translate3d("+c.x+"px,"+c.y+"px,0)";
    }
    // drip (accelerates with intensity)
    state.dripTimer += dt*1000;
    const di=dripInterval();
    if(state.dripTimer>=di){ state.dripTimer-=di; drip(); }
    // burst: when you keep the board low (outpacing the drip), periodically flood you — scales with skill
    state.burstCd -= dt*1000;
    if(state.cards.length <= FLOOR+1 && state.burstCd<=0){ burst(); state.burstCd = 14000 - 6000*inten; }
  }
  requestAnimationFrame(loop);
}
function dripInterval(){
  const d=cfg();
  return d.dripStart - (d.dripStart-d.dripMin)*intensity();
}
function drip(){
  if(state.cards.length >= state.capacity){ gameOver("overflow"); return; }
  spawnCard();
}
requestAnimationFrame(loop);
window.addEventListener("resize",()=>{ if(state.phase==="playing"){ state.fieldW=field.clientWidth; state.fieldH=field.clientHeight; } });

/* ===== FLOW ===== */
function show(name){ for(const k in screens) screens[k].classList.toggle("active", k===name); }
function setAssist(on){
  state.showWordForce=on;
  const want = on || state.diff==="easy" || !state.ttsOK;
  field.classList.toggle("assist", want);
  const b=$("assist-btn"); if(b) b.classList.toggle("active", want);
  renderTargetHint();
}
function startGame(){
  initAudio(); buildPool(); bgmStart(); state.clearTimes=[]; state.wordLog={}; state.wordSeq=0;
  state.capacity = Math.min(cfg().capacity, state.pool.length);
  state.phase="playing"; state.frozen=false;
  state.score=0; state.displayScore=0; state.combo=0; state.maxCombo=0;
  state.cleared=0; state.wrong=0; state.goldCount=0;
  state.elapsed=0; state.dripTimer=0; state.burstCd=9000; state.drift=cfg().driftBase;
  state.target=null; state.targetAt=0; state.cards=[];
  state.ttsOK=("speechSynthesis" in window); state.showWordForce=false; ttsProbed=false; ttsSpoke=false;
  field.innerHTML=""; field.classList.remove("danger"); ensureRival();
  $("score").textContent="0"; $("assist-btn").classList.remove("active");
  updateHUD(false);
  show("game");
  void field.offsetWidth; measureField();
  for(let i=0;i<cfg().start;i++) spawnCard();
  ensureFloor();
  pickNextTarget();             // first speak runs inside the start-click gesture
  updateFill();
}
function logWord(w,kind){
  if(!state.wordLog) state.wordLog={};
  let e=state.wordLog[w.en];
  if(!e) e=state.wordLog[w.en]={w:w,got:0,taken:0,seq:state.wordSeq++};
  e[kind]++;
}
function renderWordList(){
  const entries=Object.values(state.wordLog||{});
  entries.sort((a,b)=> ((b.taken>0)-(a.taken>0)) || a.seq-b.seq);
  $("wordlist").innerHTML = entries.length ? entries.map(e=>{
    const w=e.w;
    return '<div class="wrow'+(e.taken>0?' taken':'')+'" data-ja="'+w.ja+'">'+
      '<span class="we">'+w.emoji+'</span><span class="wen">'+w.ja+'</span><span class="wja">'+w.en+'</span>'+
      (e.taken>0?'<span class="wtk">\uD83D\uDC3E \u00D7'+e.taken+'</span>':'')+'</div>';
  }).join("") : '<div class="wrow"><span class="wja">(no cards)</span></div>';
}
function gameOver(reason){
  state.phase="over"; state.frozen=true; bgmStop(); cancelHand();
  if("speechSynthesis" in window) speechSynthesis.cancel();
  let newBest=false;
  if(state.score>state.best){ state.best=state.score; newBest=true; }
  if(state.cleared>state.bestCleared) state.bestCleared=state.cleared;
  if(state.elapsed>state.bestTime) state.bestTime=state.elapsed;
  saveBest(); renderBest();

  const c=state.cleared, total=c+state.wrong, acc= total? Math.round(c/total*100):0, t=state.elapsed/1000;
  let rank,col;
  if(c>=70){rank="S+";col="var(--gold)";}
  else if(c>=50){rank="S";col="var(--gold)";}
  else if(c>=34){rank="A";col="var(--jade)";}
  else if(c>=20){rank="B";col="var(--silver)";}
  else if(c>=10){rank="C";col="var(--bronze)";}
  else{rank="D";col="var(--text-dim)";}

  $("over-title").textContent="Overflowed!";
  $("over-sub").textContent = "Cleared "+c+" cards · survived "+t.toFixed(1)+"s (accuracy "+acc+"%)";
  const rb=$("rank-badge"); rb.innerHTML='<small>RANK</small>'+rank; rb.style.color=col;
  $("final-score").textContent=state.score.toLocaleString();
  $("stat-cleared").textContent=c;
  $("stat-time").textContent=t.toFixed(1)+"s";
  $("stat-combo").textContent=state.maxCombo;
  $("newbest").style.display=newBest?"inline-block":"none";
  $("audio-warn").style.display=state.ttsOK?"none":"block";
  renderWordList();
  sfxOver();
  show("over");
}


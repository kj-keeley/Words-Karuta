/* ===== BGM (generative 陰旋法 + water bed, intensity-linked) ===== */
let bgm=null;
const BGM_SCALE=[220,261.63,293.66,329.63,392,440,523.25,587.33]; /* A3 C4 D4 E4 G4 A4 C5 D5 */
function bgmStart(){
  if(!actx || !state.bgmOn || bgm || vol.bgm<=0) return;
  const master=actx.createGain(); master.gain.setValueAtTime(0.0001,actx.currentTime);
  master.gain.exponentialRampToValueAtTime(Math.max(0.0001,vol.bgm),actx.currentTime+1.4); master.connect(actx.destination);
  const len=2*actx.sampleRate, buf=actx.createBuffer(1,len,actx.sampleRate), d=buf.getChannelData(0);
  for(let i=0;i<len;i++) d[i]=Math.random()*2-1;
  const src=actx.createBufferSource(); src.buffer=buf; src.loop=true;
  const lp=actx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=420;
  const wg=actx.createGain(); wg.gain.value=0.05;
  src.connect(lp); lp.connect(wg); wg.connect(master); src.start();
  bgm={master,src,lp,wg,timer:null,stopped:false};
  bgmTick();
}
function bgmTick(){
  if(!bgm||bgm.stopped) return;
  const inten=(state.phase==="playing")?intensity():0;
  bgm.lp.frequency.setTargetAtTime(420+760*inten, actx.currentTime, .5);
  bgm.wg.gain.setTargetAtTime(0.05+0.09*inten, actx.currentTime, .5);
  const f=BGM_SCALE[rand(BGM_SCALE.length)]*(Math.random()<0.18?2:1);
  bgmPluck(f, 0.10+0.05*inten, 0);
  if(inten>0.55 && Math.random()<0.4) bgmPluck(BGM_SCALE[rand(BGM_SCALE.length)], 0.09, 0.09);
  bgm.timer=setTimeout(bgmTick, (700-460*inten)*(0.75+Math.random()*0.5));
}
function bgmPluck(freq,peak,delay){
  if(!actx||!bgm) return;
  const t0=actx.currentTime+(delay||0), o=actx.createOscillator(), g=actx.createGain();
  o.type="triangle"; o.frequency.setValueAtTime(freq,t0);
  g.gain.setValueAtTime(0.0001,t0); g.gain.exponentialRampToValueAtTime(peak,t0+0.015);
  g.gain.exponentialRampToValueAtTime(0.0001,t0+0.7);
  o.connect(g); g.connect(bgm.master); o.start(t0); o.stop(t0+0.75);
}
function bgmStop(){
  if(!bgm) return;
  bgm.stopped=true; clearTimeout(bgm.timer);
  try{
    bgm.master.gain.cancelScheduledValues(actx.currentTime);
    bgm.master.gain.setTargetAtTime(0.0001,actx.currentTime,.25);
    const b=bgm; setTimeout(()=>{ try{b.src.stop();}catch(e){} },800);
  }catch(e){}
  bgm=null;
}
function bgmDuck(){
  if(!bgm||!actx) return;
  const g=bgm.master.gain, t=actx.currentTime;
  g.cancelScheduledValues(t); g.setTargetAtTime(Math.max(0.0001,0.22*vol.bgm),t,0.05); g.setTargetAtTime(Math.max(0.0001,vol.bgm),t+1.0,0.3);
}

/* ===== TTS ===== */
let voicesReady=false, jaVoice=null, ttsSpoke=false, ttsProbed=false;
function loadVoices(){
  if(!("speechSynthesis" in window)){ state.ttsOK=false; return; }
  const vs=speechSynthesis.getVoices();
  if(vs.length){
    voicesReady=true;
    jaVoice = vs.find(v=>/ja[-_]JP/i.test(v.lang)&&/google|kyoko|natural|nanami|o-?ren/i.test(v.name))
          || vs.find(v=>/ja[-_]JP/i.test(v.lang)) || vs.find(v=>/^ja/i.test(v.lang)) || null;
  }
}
if("speechSynthesis" in window){ loadVoices(); speechSynthesis.onvoiceschanged=loadVoices; } else state.ttsOK=false;
function speakTarget(){
  if(!state.target) return;
  if(!("speechSynthesis" in window)){ state.ttsOK=false; setAssist(state.showWordForce); return; }
  try{
    if(speechSynthesis.speaking||speechSynthesis.pending) speechSynthesis.cancel();
    if(!voicesReady) loadVoices();
    bgmDuck();
    const u=new SpeechSynthesisUtterance(state.target.ja);
    u.lang="ja-JP"; u.rate=0.95; u.pitch=1.0; u.volume=vol.tts; if(jaVoice) u.voice=jaVoice;
    u.onstart=()=>{ ttsSpoke=true; };
    speechSynthesis.speak(u);
    probeTTS();
  }catch(e){ state.ttsOK=false; setAssist(state.showWordForce); }
}
function probeTTS(){
  if(ttsProbed) return; ttsProbed=true;
  setTimeout(()=>{
    if(!ttsSpoke && !(("speechSynthesis" in window)&&speechSynthesis.speaking)){
      state.ttsOK=false; setAssist(true);
      const h=$("target-hint"); if(h && !state.target) h.textContent="";
      renderTargetHint();
    }
  },850);
}

/* ===== RIVAL HAND ===== */
const hand={warn:null,timer:null,arrive:null,el:null,reaching:false,dock:null};
const POUNCE_IMG='<img src="data:image/png;base64," alt="">';
const PAW_IMG='<img src="data:image/png;base64," alt="">';
function ensureRival(){
  const d=document.createElement("div"); d.className="rival peek"; d.innerHTML=PAW_IMG;
  field.appendChild(d); hand.dock=d;
}
function sfxSnatch(){ tone(720,0,0.05,"triangle",0.13); tone(520,0.05,0.12,"triangle",0.12); }
function scheduleHand(){
  cancelHand();
  if(state.phase!=="playing"||!state.target) return;
  if(hand.dock){ hand.dock.classList.remove("itch"); hand.dock.classList.add("peek"); }
  const ms=cfg().snatchMs;
  hand.warn=setTimeout(()=>{ if(hand.dock){ hand.dock.classList.remove("peek"); hand.dock.classList.add("itch"); } }, Math.max(250, ms-1000));
  hand.timer=setTimeout(startReach, ms);
}
function startReach(){
  if(state.phase!=="playing"||!state.target||state.frozen) return;
  const c=state.cards.find(k=>k.w===state.target); if(!c) return;
  const cx=c.x+state.cs/2, cy=c.y+state.cs/2;
  const el=document.createElement("div"); el.className="pounce"; el.innerHTML=POUNCE_IMG;
  el.style.transform="translate("+(state.fieldW-30)+"px,"+(state.fieldH/2-56)+"px) rotate(6deg) scale(.8)";
  field.appendChild(el); hand.el=el; hand.reaching=true;
  if(hand.dock) hand.dock.style.opacity="0.18";
  void el.offsetWidth;
  el.style.transform="translate("+(cx-16)+"px,"+(cy-42)+"px) rotate(-3deg) scale(1.05)";
  hand.arrive=setTimeout(snatch,600);
}
function snatch(){
  if(!hand.reaching) return;
  hand.reaching=false;
  if(hand.dock) hand.dock.classList.remove("itch");
  const c=state.cards.find(k=>k.w===state.target);
  if(c){
    spawnPopup(c,"taken", c.w.ja+" = "+c.w.en, "The cat took it!");
    logWord(c.w,"taken");
    sfxSnatch();
    removeCard(c);
    state.combo=0;
  }
  cleanupHandEl();
  if(state.cards.length<state.capacity) spawnCard();
  if(state.cards.length<state.capacity) spawnCard();
  ensureFloor(); pickNextTarget(); updateHUD(true); updateFill();
}
function cleanupHandEl(){ if(hand.el){ const e=hand.el; e.style.opacity="0"; setTimeout(()=>{try{e.remove();}catch(x){}},280); hand.el=null; } if(hand.dock) hand.dock.style.opacity="1"; }
function cancelHand(){
  clearTimeout(hand.warn); clearTimeout(hand.timer); clearTimeout(hand.arrive);
  if(hand.dock){ hand.dock.classList.remove("itch"); hand.dock.classList.add("peek"); }
  const was=hand.reaching; hand.reaching=false; cleanupHandEl();
  return was;
}

/* ===== POOL ===== */
function buildPool(){ state.pool = state.category==="all" ? WORDS.slice() : WORDS.filter(w=>w.cat===state.category); }
function measureField(){
  state.fieldW=field.clientWidth; state.fieldH=field.clientHeight;
  state.cs=Math.round(Math.max(54, Math.min(86, Math.min(state.fieldW*0.205, state.fieldH*0.235))));
}

/* ===== CARDS ===== */
function spawnCard(){
  const used=new Set(state.cards.map(c=>c.w.emoji));
  let cand=state.pool.filter(w=>!used.has(w.emoji));
  if(cfg().sameCat && state.cards.length){
    const anchor=state.cards[rand(state.cards.length)].w;
    const same=cand.filter(w=>w.cat===anchor.cat);
    if(same.length) cand=same;
  }
  if(!cand.length) return false;
  const w=cand[rand(cand.length)];
  const cs=state.cs, W=state.fieldW, H=state.fieldH;
  const el=document.createElement("button");
  el.className="card spawning";
  el.style.setProperty("--cs",cs+"px");
  el.style.setProperty("--d",(Math.random()*4).toFixed(2)+"s");
  el.innerHTML='<span class="bob"><span class="face"><span class="emoji">'+w.emoji+'</span><span class="word">'+w.ja+'</span></span></span>';
  const x=Math.random()*Math.max(1,W-cs), y=Math.random()*Math.max(1,H-cs);
  const c={w, el, x, y, ang:Math.random()*Math.PI*2, spd:0.7+Math.random()*0.5};
  el.style.transform="translate3d("+x+"px,"+y+"px,0)";
  el.addEventListener("pointerdown", ev=>{ ev.preventDefault(); onTap(c); });
  el.addEventListener("animationend", ()=>el.classList.remove("spawning"), {once:true});
  field.appendChild(el); state.cards.push(c);
  updateFill();
  return true;
}
function removeCard(c){
  const i=state.cards.indexOf(c); if(i>=0) state.cards.splice(i,1);
  c.el.classList.add("clearing"); c.el.style.pointerEvents="none";
  c.el.addEventListener("animationend", ()=>c.el.remove(), {once:true});
}
function ensureFloor(){
  let guard=0;
  while(state.cards.length < FLOOR && guard++ < FLOOR+1){ if(!spawnCard()) break; }
}
function burst(){
  const room = Math.max(0, state.capacity - state.cards.length - 1);
  const want = BURST_MIN + Math.round(intensity()*(BURST_MAX-BURST_MIN));
  const size = Math.min(want, room);
  for(let i=0;i<size;i++){ if(!spawnCard()) break; }
}
function pickNextTarget(){
  if(state.cards.length===0){ state.target=null; cancelHand(); renderTargetHint(); return; }
  state.target = state.cards[rand(state.cards.length)].w;
  state.targetAt = performance.now();
  renderTargetHint();
  speakTarget();
  scheduleHand();
}
function renderTargetHint(){
  const h=$("target-hint");
  const assist = state.showWordForce || state.diff==="easy" || !state.ttsOK;
  field.classList.toggle("assist", assist);
  if(!state.target){ h.textContent=""; return; }
  h.innerHTML = assist ? "<b>"+state.target.ja+"</b>" : "🔊 Tap the card for the word you hear";
}

/* ===== INPUT ===== */
function onTap(c){
  if(state.frozen || state.phase!=="playing" || !state.target) return;
  if(c.w === state.target){
    const blocked = cancelHand();
    const ms = performance.now()-state.targetAt;
    if(!state.clearTimes) state.clearTimes=[];
    state.clearTimes.push(performance.now()); if(state.clearTimes.length>6) state.clearTimes.shift();
    logWord(c.w,"got");
    const d=cfg();
    let tier, mult;
    if(ms<=d.goldMs){tier="gold";mult=3;} else if(ms<=d.silverMs){tier="silver";mult=2;} else {tier="bronze";mult=1;}
    if(tier==="gold") state.goldCount++;
    state.combo++; state.maxCombo=Math.max(state.maxCombo,state.combo); state.cleared++;
    const comboMult=Math.min(4, 1+Math.floor(state.combo/5)*0.5);
    const crowd=state.cards.length/state.capacity;                 // clutch bonus when board is full
    const crowdMult=1 + (crowd>0.6 ? (crowd-0.6)*1.0 : 0);
    let pts=Math.round(100*mult*comboMult*crowdMult);
    let crit=false; if(tier==="gold" && comboMult>=2){ crit=true; pts=Math.round(pts*1.5); }
    state.score+=pts;
    spawnPopup(c, (blocked?"crit ":(crit?"crit ":""))+tier, (blocked?"BLOCKED!":(crit?"CRITICAL!":tier.toUpperCase())), (comboMult>1?("×"+comboMult.toFixed(comboMult%1?1:0)+" "):"")+"+"+pts);
    confetti(c, crit?20:(tier==="gold"?14:9), crit);
    sfxClear(tier, crit);
    removeCard(c);
    ensureFloor();
    pickNextTarget();
    updateHUD(true); updateFill();
  } else {
    state.combo=0; state.wrong++;
    state.score=Math.max(0, state.score-40);
    c.el.classList.remove("wrongflash"); void c.el.offsetWidth; c.el.classList.add("wrongflash");
    sfxWrong();
    updateHUD(true);
  }
}

/* ===== FX ===== */
const livePops=[];
function popLife(){
  const t=state.clearTimes||[];
  if(t.length<2) return 950;
  let sum=0;
  for(let i=1;i<t.length;i++) sum+=t[i]-t[i-1];
  return Math.max(450, Math.min(1500, (sum/(t.length-1))*0.8));
}
function spawnPopup(c, cls, tier, pts){
  const el=document.createElement("div");
  el.className="popup "+cls;
  const isEvent = cls.indexOf("taken")>=0 || tier==="\u963B\u6B62\uFF01";
  el.style.animationDuration=(isEvent?2000:popLife())+"ms";
  el.innerHTML='<span class="tier">'+tier+'</span>'+(pts?'<span class="pts">'+pts+'</span>':'');
  el.style.left=(c.x+state.cs/2)+"px"; el.style.top=(c.y+state.cs/2)+"px";
  field.appendChild(el);
  el.addEventListener("animationend",()=>{ el.remove(); const i=livePops.indexOf(el); if(i>=0) livePops.splice(i,1); });
  if(!isEvent){
    livePops.push(el);
    while(livePops.length>2){
      const old=livePops.shift();
      old.style.transition="opacity .12s"; old.style.opacity="0";
      setTimeout(()=>{ try{old.remove();}catch(e){} },130);
    }
  }
}
const CONF=["#ecc24f","#e2483d","#5cb586","#cfd6e2","#f4d678","#ef5a4d"];
function confetti(c, count, gold){
  const cx=c.x+state.cs/2, cy=c.y+state.cs/2;
  for(let i=0;i<count;i++){
    const p=document.createElement("div"); p.className="confetti";

/* difficulty escalation: 0 during warmup, then ramps 0->1 over ESCALATE sec */
const WARMUP = 18;            // gentle warmup seconds (tune 15-20)
const ESCALATE = 45;         // seconds to reach full intensity after warmup
const FLOOR = 3;             // board never drops below this (kills the 1-card no-listen tap)
const BURST_MIN = 5, BURST_MAX = 8;
const DRIFT_MAX_MULT = 2.1;  // card speed multiplier at full intensity
function intensity(){
  const t=state.elapsed/1000;
  if(t<=WARMUP) return 0;
  return Math.min(1,(t-WARMUP)/ESCALATE);
}


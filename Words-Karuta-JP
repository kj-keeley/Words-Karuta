/* ===== AUDIO ===== */
let actx=null;
function initAudio(){ if(actx){ if(actx.state==="suspended") actx.resume(); return; } try{ actx=new (window.AudioContext||window.webkitAudioContext)(); }catch(e){ actx=null; } }
function tone(freq,start,dur,type,peak){
  if(!actx) return;
  const t0=actx.currentTime+start, osc=actx.createOscillator(), g=actx.createGain();
  osc.type=type||"sine"; osc.frequency.setValueAtTime(freq,t0);
  g.gain.setValueAtTime(0.0001,t0); g.gain.exponentialRampToValueAtTime(Math.max(0.0001,(peak||0.16)*vol.sfx),t0+0.012);
  g.gain.exponentialRampToValueAtTime(0.0001,t0+dur);
  osc.connect(g); g.connect(actx.destination); osc.start(t0); osc.stop(t0+dur+0.02);
}
function sfxClear(tier,crit){
  if(!actx) return;
  if(crit){ [784,988,1175,1568].forEach((f,i)=>tone(f,i*0.05,0.2,"triangle",0.15)); return; }
  if(tier==="gold"){ [659,880,1109].forEach((f,i)=>tone(f,i*0.05,0.18,"triangle",0.15)); }
  else if(tier==="silver"){ [587,784].forEach((f,i)=>tone(f,i*0.055,0.16,"triangle",0.14)); }
  else { tone(523,0,0.14,"triangle",0.13); }
}

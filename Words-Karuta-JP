function bindVol(key){
  const sl=$("vol-"+key), vv=$("volv-"+key);
  sl.value=Math.round(vol[key]*100); vv.textContent=sl.value;
  sl.addEventListener("input",()=>{
    vol[key]=sl.value/100; vv.textContent=sl.value; saveVol();
    if(key==="bgm"){
      if(bgm&&actx){ const g=bgm.master.gain,t=actx.currentTime; g.cancelScheduledValues(t); g.setTargetAtTime(Math.max(0.0001,vol.bgm),t,0.1); if(vol.bgm<=0){bgmStop();} }
      else if(state.phase==="playing"&&state.bgmOn&&vol.bgm>0){ initAudio(); bgmStart(); }
    }
    if(key==="sfx"){ initAudio(); tone(659,0,0.12,"triangle",0.15); }
  });
}
$("wordlist").addEventListener("click",ev=>{
  const r=ev.target.closest(".wrow"); if(!r||!r.dataset.ja) return;
  try{
    if(!("speechSynthesis" in window)) return;
    speechSynthesis.cancel();
    const u=new SpeechSynthesisUtterance(r.dataset.ja);
    u.lang="ja-JP"; u.rate=0.95; u.volume=vol.tts; if(jaVoice) u.voice=jaVoice;
    speechSynthesis.speak(u);
  }catch(e){}
});
loadVol(); ["tts","bgm","sfx"].forEach(bindVol);
loadBest();
</script>
